# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=carbontrack
DB_USERNAME=root
DB_PASSWORD=

# JWT Configuration
# Use a long random secret of at least 32 bytes.
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes
JWT_ALGORITHM=HS256
# Recommended default tightened from 86400 (24h) to 7200 (2h) so a stolen token
# expires faster; pair with users.token_version + change-password to revoke early.
JWT_EXPIRATION=7200
# Clock-skew tolerance in seconds. Capped to 300 at runtime to prevent overly
# lax env values from accepting expired tokens indefinitely.
JWT_LEEWAY=60

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_DISABLE_TLS_VERIFY=1
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=carbontrack-images
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-custom-domain.com

# Turnstile Configuration
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# Optional TLS trust settings for PHP cURL on Windows or custom CA environments.
# Prefer TURNSTILE_CA_BUNDLE when your PHP/cURL runtime cannot locate a valid root CA chain.
TURNSTILE_CA_BUNDLE=
# Enable native OS CA store when supported by your cURL build.
TURNSTILE_USE_NATIVE_CA_STORE=false

# Mobile proof-of-work protection for anonymous auth endpoints.
# POW_SECRET defaults to JWT_SECRET when omitted; set a separate long random value in production.
POW_SECRET=
# Recommended difficulty raised from 16 to 22 to slow down brute-force attempts
# (~64 MiB hashes vs ~64 KiB). Adjust based on observed legitimate client perf.
POW_DIFFICULTY=22
POW_TTL_SECONDS=120
# Shared secret a mobile build must echo back via X-Mobile-Client-Token to be
# allowed onto the PoW path; leave empty to disable the mobile bypass entirely
# and force every client through Turnstile.
MOBILE_CLIENT_TOKEN=
# Comma-separated proxy CIDRs whose CF-Connecting-IP / X-Forwarded-For headers
# may be trusted for auth lockout and proof-of-work issuance limits.
TRUSTED_PROXY_CIDRS=

# Email Configuration (for verification codes)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls

MAIL_SIMULATE=false

MAIL_SMTP_DEBUG=0

EMAIL_VERIFICATION_TTL_MINUTES=30
MAIL_FROM_ADDRESS=your-email@gmail.com
MAIL_FROM_NAME="CarbonTrack"
SUPPORT_EMAIL=support@carbontrackapp.com
SUPPORT_SLA_SWEEP_KEY=
SUPPORT_ROUTING_AUDIT_LIMIT=10
CRON_RUN_KEY=
# Cron endpoint observability. Disabled by default to avoid noisy scheduler polling logs.
# Set to true if /api/v1/cron/run should write request-level system_logs.
CRON_ENDPOINT_SYSTEM_LOGS_ENABLED=false
# Set to true if /api/v1/cron/run and cron_endpoint task runs should write audit_logs.
CRON_ENDPOINT_AUDIT_LOGS_ENABLED=false

# AI Assistant (OpenAI-compatible)
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_MODEL=gpt-4o-mini
LLM_API_TEMPERATURE=0.2
LLM_API_MAX_TOKENS=800
# Set to 0 to omit max_tokens and let the provider use its own output limit.
ADMIN_AI_MAX_TOKENS=4096
LLM_API_ORG=
LLM_TIMEOUT_SECONDS=90
LLM_CONNECT_TIMEOUT_SECONDS=10
ADMIN_AI_COMMANDS_PATH=

# Passkey Configuration
# PASSKEYS_RP_ID must equal the frontend hostname or be its parent suffix.
# Example: https://dev.carbontrackapp.com can use dev.carbontrackapp.com or carbontrackapp.com.
PASSKEYS_ENABLED=true
PASSKEYS_RP_ID=localhost
PASSKEYS_RP_NAME=CarbonTrack
PASSKEYS_ORIGINS=http://localhost:3000

# Application Configuration
APP_NAME=CarbonTrack
# Default-deny: when unset, public/index.php now coerces APP_ENV to 'production'
# so missing config never lands in the lax 'development' branch.
APP_ENV=development
APP_DEBUG=true
# Explicit opt-in for AuthMiddleware/AdminMiddleware testing fallbacks.
# Must be paired with APP_ENV=testing; production deployments must keep this false.
ALLOW_TEST_AUTH_FALLBACK=false
# Explicit opt-in for skipping Turnstile in non-production environments.
# Production deployments ignore this flag and always require a verified token.
ALLOW_TURNSTILE_BYPASS=false
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
REGION_DATA_PATH=backend/storage/data/states.json
QUOTA_DEFINITIONS=llm.daily_limit,llm.rate_limit,checkin_makeup.monthly_limit
# Optional write guards for local debugging. Leave unset by default; set to true to disable DB writes.
# DISABLE_AUDIT_LOG_WRITES=true
# DISABLE_ERROR_LOG_WRITES=true
# DISABLE_SYSTEM_LOG_WRITES=true

# Leaderboard cache trigger (used by /api/v1/leaderboard/trigger)
LEADERBOARD_TRIGGER_KEY=please-set-a-secure-key
LEADERBOARD_CACHE_TTL=600

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=debug
LOG_PATH=logs/app.log

